# whale config — copy to .env (gitignored). Loaded natively by Node 22+.
#   cp .env.example .env
#
# The runtime dials below (runner, models, bypass, autopush, allow-new) are also
# editable live from the Settings tab (PATCH /api/config) — a DB override wins over
# the env value, no restart. WHALE_PROTECTED + wiring stay env-only. See
# docs/config-ui-overrides.md.

# --- runner ---
# stub = deterministic, offline, no cost.  real = spawns the Claude Code CLI
# (uses your Claude Code auth — no API key, no separate billing).
WHALE_RUNNER=stub
CLAUDE_BIN=claude
WHALE_CLAUDE_TIMEOUT=240000

# model tiering (CLI aliases). triage is deterministic — no model.
# Defaults (lib/config.ts): plan=sonnet, route=haiku.
WHALE_MODEL_PLAN=sonnet
WHALE_MODEL_ROUTE=haiku

# --- autonomy dials ---
# which risk tiers may bypass your review: conservative | balanced | aggressive
WHALE_BYPASS=conservative
# push approved tasks to krill automatically (1) vs. leave staged (0)
WHALE_AUTOPUSH=0
# allow the router to PROPOSE new projects (creation stays human-gated regardless)
WHALE_ALLOW_NEW_PROJECTS=0
# self-modification guard: tasks targeting these projects ALWAYS get human
# review and never bypass (a bad self-edit can break the automation).
WHALE_PROTECTED=whale,krill

# --- wiring ---
# Port is set by the start script (next start -p 4100), not env.
KRILL_URL=http://localhost:3000
# path to the ai-team personas repo (source of truth). default: ../ai-team
# PERSONAS_DIR=/Users/gustavokrause/code/ai-team

# --- storage (defaults are fine) ---
# DB_PATH=data/whale.db          # sqlite file (drizzle + better-sqlite3)
# WHALE_CONTEXT_DIR=./data/context
